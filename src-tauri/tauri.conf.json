{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "fpasoterm",
  "version": "../package.json",
  "identifier": "io.github.oyoguhito.fpasoterm",
  "mainBinaryName": "fpasoterm",
  "build": {
    "beforeBuildCommand": "",
    "beforeDevCommand": "",
    "frontendDist": "../src/renderer",
    "devUrl": null
  },
  "app": {
    "withGlobalTauri": true,
    "enableGTKAppId": false,
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self' asset: http://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' asset: http://asset.localhost"
    },
    "windows": [
      {
        "label": "main",
        "title": "fpasoterm",
        "width": 1000,
        "height": 680,
        "minWidth": 420,
        "minHeight": 260,
        "decorations": false,
        "transparent": true,
        "backgroundColor": "#00000000",
        "resizable": true,
        "center": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "../extra/logo/fpasoterm.png",
      "../extra/macos/fpasoterm.icns",
      "../extra/windows/fpasoterm.ico"
    ],
    "linux": {
      "deb": {
        "depends": []
      }
    },
    "macOS": {
      "signingIdentity": "-"
    }
  }
}
